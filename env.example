# Copy this file to env.local or .env and fill only the values needed locally.
# Do not commit real tokens, usernames, passwords, cookies, or private URLs.

FLOODCASTTW_DATA_DIR=data
FLOODCASTTW_LOG_LEVEL=INFO

# Public data endpoints. Override only when testing mirrors or staging services.
WRA_BASE_URL=https://fhy.wra.gov.tw/fhyv2
CWA_CODIS_URL=https://codis.cwa.gov.tw/StationData
CWA_OPEN_DATA_FILE_API_URL=https://opendata.cwa.gov.tw/fileapi/v1/opendataapi
CWA_HISTORY_API_URL=https://opendata.cwa.gov.tw/historyapi/v1/getMetadata
CWA_HISTORY_DATA_API_URL=https://opendata.cwa.gov.tw/historyapi/v1/getData
NCDR_OPEN_API_URL=https://watch.ncdr.nat.gov.tw/watch

# Optional credentials for future official APIs. Keep blank in git.
CWA_API_KEY=
NCDR_API_KEY=
