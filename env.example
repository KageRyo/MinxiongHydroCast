# Copy this file to env.local or .env and fill only the values needed locally.
# Do not commit real tokens, usernames, passwords, cookies, or private URLs.

FLOODCASTMINXIONG_DATA_DIR=data
FLOODCASTMINXIONG_LOG_LEVEL=INFO
FLOODCASTMINXIONG_OPERATIONS_STORE=data/processed/operations
FLOODCASTMINXIONG_MAX_AGE_MINUTES=30
FLOODCASTMINXIONG_FLOOD_MAX_AGE_MINUTES=90

# Public data endpoints. Override only when testing mirrors or staging services.
WRA_BASE_URL=https://fhy.wra.gov.tw/fhyv2
WRA_API_URL=https://fhy.wra.gov.tw/OpenApiv3
WRA_OPEN_DATA_API_URL=https://opendata.wra.gov.tw/api/v2
CWA_CODIS_URL=https://codis.cwa.gov.tw/StationData
CWA_REST_API_URL=https://opendata.cwa.gov.tw/api/v1/rest/datastore
CWA_OPEN_DATA_FILE_API_URL=https://opendata.cwa.gov.tw/fileapi/v1/opendataapi
CWA_HISTORY_API_URL=https://opendata.cwa.gov.tw/historyapi/v1/getMetadata
CWA_HISTORY_DATA_API_URL=https://opendata.cwa.gov.tw/historyapi/v1/getData
NCDR_OPEN_API_URL=https://watch.ncdr.nat.gov.tw/watch

# Runtime credentials for official APIs. Keep blank in git.
CWA_API_KEY=
WRA_API_KEY=
# Optional Discord incoming webhook for operational alerts. Keep the full URL secret.
FLOODCAST_DISCORD_WEBHOOK_URL=
# Optional credentials for official adapters not implemented yet.
NCDR_API_KEY=
