# Copy to .env for local use. The repository ignores .env and *.env files.
# Never commit credentials, webhook URLs, cookies, or other private values.

# Required for the strict live collector and official-source contract checks.
CWA_API_KEY=
WRA_API_KEY=

# Optional. Blank keeps Discord delivery disabled; the URL is a secret.
MINXIONGHYDROCAST_DISCORD_WEBHOOK_URL=

# Operational snapshot location and freshness thresholds. CLI flags override these defaults.
MINXIONGHYDROCAST_OPERATIONS_STORE=data/processed/operations
MINXIONGHYDROCAST_MAX_AGE_MINUTES=30
MINXIONGHYDROCAST_FLOOD_MAX_AGE_MINUTES=90

# Dataset builds and continuous event evidence stay outside Git. Use a durable mounted path.
# The single-host installer derives DURABLE_ROOT-research when this is omitted.
# MINXIONGHYDROCAST_RESEARCH_ROOT=/durable/path/minxiong-hydrocast-research

# Advanced endpoint overrides. Keep these defaults unless testing an approved mirror or staging API.
WRA_API_URL=https://fhy.wra.gov.tw/OpenApiv3
WRA_OPEN_DATA_API_URL=https://opendata.wra.gov.tw/api/v2
WRA_BASE_URL=https://fhy.wra.gov.tw/fhyv2
CWA_REST_API_URL=https://opendata.cwa.gov.tw/api/v1/rest/datastore
CWA_OPEN_DATA_FILE_API_URL=https://opendata.cwa.gov.tw/fileapi/v1/opendataapi
CWA_HISTORY_API_URL=https://opendata.cwa.gov.tw/historyapi/v1/getMetadata
CWA_HISTORY_DATA_API_URL=https://opendata.cwa.gov.tw/historyapi/v1/getData
